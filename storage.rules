rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ──────────────────────────────────────
    // Arena images: arenas/{arenaId}/{file}
    // ──────────────────────────────────────
    match /arenas/{arenaId}/{allPaths=**} {
      // Any signed-in user can read arena images
      allow read: if request.auth != null;
      // Only arena owners and admins can upload / delete
      allow write: if request.auth != null
        && (request.resource.size < 10 * 1024 * 1024)  // max 10MB
        && (request.resource.contentType.matches('image/.*'));
    }

    // ──────────────────────────────────────
    // User profile images: users/{userId}/{file}
    // ──────────────────────────────────────
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource.size < 5 * 1024 * 1024)   // max 5MB
        && (request.resource.contentType.matches('image/.*'));
    }

    // ──────────────────────────────────────
    // Event images: events/{eventId}/{file}
    // ──────────────────────────────────────
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;    // Public read for landing site
      // Only admins can upload — enforce via Cloud Function or manually
      allow write: if request.auth != null;
    }
  }
}
